# API Server port
PORT=8080

# Client nginx port (used by docker-compose for the frontend container)
CLIENT_PORT=3000

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRY_HOURS=72

# PostgreSQL (Railway provides DATABASE_URL, but we use POSTGRES_DSN)
# On Railway: set this to the Postgres service's connection string
POSTGRES_DSN=postgresql://user:password@localhost:5432/bol_lms?sslmode=disable

# MinIO / S3-compatible object storage
MINIO_ENDPOINT=localhost:9000
# MINIO_PUBLIC_URL is the *externally* reachable base URL of MinIO that browsers
# can reach directly.  In containerised / Railway deployments the internal
# endpoint (MINIO_ENDPOINT) is not reachable from the public internet, so
# presigned URLs must be rewritten to use this public URL instead.
# Example (Railway):  MINIO_PUBLIC_URL=https://minio-production.up.railway.app
# Example (local):    leave empty — MINIO_ENDPOINT is already accessible
MINIO_PUBLIC_URL=
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_USE_SSL=false
MINIO_BUCKET_VIDEOS=bol-lms-videos
MINIO_BUCKET_DOCS=bol-lms-documents

# Seed dummy accounts on startup
DUMMY_SUPERADMIN_EMAIL=superadmin@bol-lms.com
DUMMY_SUPERADMIN_PASSWORD=superadminpass123
DUMMY_ADMIN_EMAIL=admin@bol-lms.com
DUMMY_ADMIN_PASSWORD=adminpass123
DUMMY_USER_EMAIL=user@bol-lms.com
DUMMY_USER_PASSWORD=userpass123
